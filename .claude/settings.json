{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/check_py.py 2>/dev/null || true",
            "timeout": 60,
            "statusMessage": "Verificando sintaxis/smoke test..."
          }
        ]
      }
    ]
  }
}
